{
  "name": "eisenhower-bases-view",
  "version": "0.1.0",
  "description": "Display notes from a Base as an Eisenhower matrix and drag cards to update their properties.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "preview:build": "node scripts/preview/build.mjs"
  },
  "keywords": [
    "obsidian",
    "bases",
    "eisenhower",
    "matrix",
    "tasks"
  ],
  "author": "Takahiro.N",
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "~6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "preact": "^10.24.0"
  },
  "devDependencies": {
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^22.7.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "jsdom": "^25.0.0",
    "obsidian": "latest",
    "prettier": "^3.9.4",
    "tslib": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  }
}
